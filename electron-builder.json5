/**
 * @see https://www.electron.build/configuration/configuration
 */
{
  appId: "dev.webmonch.nekta",
  asar: true,
  asarUnpack: [
    "out/remotion-bundle/**/*",
    "node_modules/@remotion/compositor-*/**/*",
    "node_modules/better-sqlite3/**/*",
  ],
  directories: {
    output: "release/${version}",
  },
  files: ["dist-electron", "dist", "out"],
  afterPack: "./scripts/afterPack.cjs",
  afterAllArtifactBuild: "./scripts/generateManifest.cjs",
  mac: {
    artifactName: "${productName}_${version}_${arch}.${ext}",
    target: [
      { target: "dmg", arch: ["universal"] },
      { target: "zip", arch: ["universal"] },
    ],
    hardenedRuntime: true,
    gatekeeperAssess: false,
    entitlements: "build/entitlements.mac.plist",
    entitlementsInherit: "build/entitlements.mac.plist",
    notarize: true,
    x64ArchFiles: "Contents/Resources/app.asar.unpacked/node_modules/@remotion/compositor-darwin-x64/**/*",
    singleArchFiles: "Contents/Resources/app.asar.unpacked/node_modules/@remotion/compositor-darwin-arm64/**/*",
  },
  win: {
    target: [
      {
        target: "nsis",
        arch: ["x64"],
      },
    ],
    artifactName: "${productName}_${version}.${ext}",
  },
  nsis: {
    oneClick: false,
    perMachine: false,
    allowToChangeInstallationDirectory: true,
    deleteAppDataOnUninstall: false,
  },
  linux: {
    target: ["AppImage", "snap"],
    icon: "build/icons/png",
    category: "AudioVideo",
  },
  publish: {
    provider: "generic",
    url: "https://cdn.nekta-studio.com",
    channel: "latest",
  },
}
